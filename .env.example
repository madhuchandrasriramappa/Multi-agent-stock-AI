# ── App ────────────────────────────────────────────────────────────────────────
APP_ENV=development
LOG_LEVEL=INFO

# ── Azure OpenAI ───────────────────────────────────────────────────────────────
AZURE_OPENAI_ENDPOINT=https://<your-resource>.openai.azure.com/
AZURE_OPENAI_API_KEY=<your-key>
AZURE_OPENAI_DEPLOYMENT=gpt-4o
AZURE_OPENAI_API_VERSION=2024-02-15-preview

# ── Azure PostgreSQL Flexible Server ──────────────────────────────────────────
DB_HOST=<your-server>.postgres.database.azure.com
DB_PORT=5432
DB_NAME=stockai
DB_USER=<your-admin-user>
DB_PASSWORD=<your-password>
DB_SSL_MODE=require

# ── Azure Service Bus ──────────────────────────────────────────────────────────
AZURE_SERVICEBUS_CONNECTION_STRING=Endpoint=sb://<your-namespace>.servicebus.windows.net/;SharedAccessKeyName=...
AZURE_SERVICEBUS_QUEUE_NAME=pipeline-events

# ── Azure Key Vault ────────────────────────────────────────────────────────────
AZURE_KEYVAULT_URL=https://<your-vault>.vault.azure.net/

# ── Azure Monitor / Application Insights ──────────────────────────────────────
# Leave blank during local dev — telemetry will be skipped gracefully
APPLICATIONINSIGHTS_CONNECTION_STRING=

# ── External APIs ──────────────────────────────────────────────────────────────
# CoinGecko: free tier works without a key; add one for higher rate limits
COINGECKO_API_KEY=
# Alpha Vantage: optional supplemental source
ALPHA_VANTAGE_API_KEY=

# ── Ingestion config ───────────────────────────────────────────────────────────
STOCK_SYMBOLS=AAPL,MSFT,GOOGL,TSLA,NVDA
CRYPTO_SYMBOLS=bitcoin,ethereum,solana,cardano
INGESTION_INTERVAL_MINUTES=15
